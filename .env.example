# MyRAG 本地开发环境（可选）
# 复制为 .env 并填入 AI_DASHSCOPE_API_KEY 后，docker compose up 会自动加载
AI_DASHSCOPE_API_KEY=your-api-key-here

# Docker 镜像（国内无法直连 Docker Hub 时使用；海外网络可删除或注释以下四行）
DOCKER_IMAGE_PREFIX=docker.1ms.run/library/
MYSQL_IMAGE=docker.1ms.run/library/mysql:8.4
REDIS_IMAGE=docker.1ms.run/library/redis:7-alpine
QDRANT_IMAGE=docker.1ms.run/qdrant/qdrant:v1.13.2

# MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/myrag?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8
SPRING_DATASOURCE_USERNAME=myrag
SPRING_DATASOURCE_PASSWORD=myrag

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Qdrant
SPRING_AI_VECTORSTORE_QDRANT_HOST=localhost
SPRING_AI_VECTORSTORE_QDRANT_PORT=6334
